# Copy to .env and fill in. Bun loads .env automatically.
NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://anchord:anchord@localhost:5432/anchord
# APP_SECRET — min 16 chars. Generate: openssl rand -hex 32
APP_SECRET=change-me-to-a-long-random-secret
# Email provider — REQUIRED (the app refuses to start without one). Use EITHER the full
# SMTP group OR Resend. If both are set, Resend wins.
#   a) SMTP: set HOST + PORT + USER + PASS
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=anchord
SMTP_PASS=changeme
#   b) Resend (HTTP API): set RESEND_API_KEY instead of the SMTP_* group
# RESEND_API_KEY=re_xxxxxxxx
# From address for outbound mail. Optional, but Resend/most SMTP relays REJECT senders that
# aren't on a verified domain, so set it on a real deploy to match your verified domain.
# EMAIL_FROM=Anchord <no-reply@anchord.example.com>
CORS_ORIGIN=*

# Global cap on the raw HTTP request body in bytes (default 40MB). Bun rejects an
# over-cap request with 413 before buffering it — a backstop above the largest
# legitimate upload (25MB image). Raise only if you serve larger artifacts.
# MAX_REQUEST_BODY_BYTES=41943040

APP_URL=http://localhost:5173

# --- Docker compose (self-host) only — ignored by local `bun dev` ---
# The db service + the app's DATABASE_URL are composed from these. POSTGRES_PASSWORD has NO
# default in the compose file: `docker compose up` refuses to start until you set it here.
POSTGRES_USER=anchord
POSTGRES_PASSWORD=change-me-to-a-strong-db-password
POSTGRES_DB=anchord
# APP_PORT — host port the app is published on (defaults to PORT=3000 if unset). Remap if your
# host 3000 is taken, e.g. APP_PORT=3939.
APP_PORT=3000

# Social sign-in (optional). A provider turns on only when BOTH its vars are set.
# Redirect URI to register with the provider: <baseURL>/api/auth/callback/<provider>
# e.g. dev: http://localhost:3000/api/auth/callback/google
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Bind-mount data paths (used ONLY with docker-compose.prod.yml). Where Postgres data and
# uploaded assets live on the host, so you control + back them up. Default to ./data/* if unset.
# Point at a mounted disk for a real deploy, e.g. /mnt/data/anchord/{db,assets}.
DB_DATA_DIR=./data/db
ASSETS_DATA_DIR=./data/assets
