{
  "name": "backend",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "test": "bun test",
    "test:integration": "RUN_INTEGRATION=1 bun test ./test/integration/*.itest.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "db:seed": "bun src/db/seed.ts"
  },
  "dependencies": {
    "@anchord/anchor": "workspace:*",
    "@elysiajs/cors": "^1.4.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-auth": "^1.6.14",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "isomorphic-dompurify": "^3.16.0",
    "markdown-it": "^14.2.0",
    "nodemailer": "^8.0.10",
    "postgres": "^3.4.9",
    "resend": "^6.12.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "bun-types": "^1.3.14",
    "@types/markdown-it": "^14.1.2",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^15.11.7",
    "typescript": "^6.0.3"
  }
}
